; Engine configuration file.
; Godot 4.x project used for the gradual desktop/web client migration.

config_version=5

[application]

config/name="Groundfire"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.4")
config/server_directory_url=""

[autoload]

PlatformCapabilities="*res://scripts/platform_capabilities.gd"

[display]

window/size/viewport_width=1024
window/size/viewport_height=768
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[gui]

theme/custom_font_hinting=0

[input]

gf_aim_left={
"deadzone": 0.5,
"events": []
}
gf_aim_right={
"deadzone": 0.5,
"events": []
}
gf_power_up={
"deadzone": 0.5,
"events": []
}
gf_power_down={
"deadzone": 0.5,
"events": []
}
gf_fire={
"deadzone": 0.5,
"events": []
}
gf_weapon_next={
"deadzone": 0.5,
"events": []
}
gf_pause={
"deadzone": 0.5,
"events": []
}
gf_move_left={
"deadzone": 0.5,
"events": []
}
gf_move_right={
"deadzone": 0.5,
"events": []
}
gf_weapon_prev={
"deadzone": 0.5,
"events": []
}
gf_jump={
"deadzone": 0.5,
"events": []
}

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
